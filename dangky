    let selectedCourses = []; // Mảng chứa các lớp sinh viên bấm chọn

    // TỰ ĐỘNG CHẠY NGAY KHI VÀO WEB TRÌNH DUYỆT
    window.onload = function() {
        renderDataToTable(DATABASE_HOC_PHAN);
        document.getElementById('search-input').addEventListener('input', runFilterEngine);
    };

    // ĐỔ DỮ LIỆU TỪ MẢNG CỐ ĐỊNH VÀO BẢNG HTML
    function renderDataToTable(data) {
        const tbody = document.getElementById('data-rows');
        tbody.innerHTML = '';

        data.forEach(item => {
            const tr = document.createElement('tr');
            tr.setAttribute('data-code', item.classCode);
            tr.setAttribute('data-name', item.name);

            // Kiểm tra trạng thái hàng để áp dụng logic mờ/vàng nền
            const isSelected = selectedCourses.some(x => x.classCode === item.classCode);
            const isNameLocked = selectedCourses.some(x => x.name === item.name);

            if (isSelected) {
                tr.classList.add('selected-row');
            } else if (isNameLocked) {
                tr.classList.add('muted-row');
            }

            tr.innerHTML = `
                <td><b>${item.classCode}</b></td>
                <td>${item.name}</td>
                <td><small>${item.schedule}</small></td>
                <td>${item.teacher}</td>
                <td>${item.credits}</td>
                <td align="center">
                    ${isSelected ? 
                        `<button style="color: #ff0000; font-weight: bold; font-family: 'Times New Roman';" onclick="handleSelectToggle('${item.classCode}')">HUY CHON</button>` : 
                        `<button style="color: #0000ff; font-weight: bold; font-family: 'Times New Roman';" onclick="handleSelectToggle('${item.classCode}')">CHON</button>`
                    }
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    // LOGIC CLICK CHỌN / HỦY CHỌN & KHÓA MÔN TRÙNG TÊN MÔN HỌC
    function handleSelectToggle(code) {
        const index = selectedCourses.findIndex(x => x.classCode === code);
        if (index > -1) {
            selectedCourses.splice(index, 1); // Khôi phục môn nếu bấm Hủy chọn
        } else {
            const matchObj = DATABASE_HOC_PHAN.find(x => x.classCode === code);
            selectedCourses.push(matchObj); // Khóa các môn trùng tên nếu bấm Chọn
        }
        renderDataToTable(DATABASE_HOC_PHAN);
        runFilterEngine(); // Giữ nguyên bộ lọc tìm kiếm hiện tại
    }

    // BỘ SÀNG LỌC TÌM KIẾM ĐA NĂNG KHÔNG PHÂN BIỆT DẤU CHẤM (.)
    function runFilterEngine() {
        const searchInputText = document.getElementById('search-input').value.trim().toLowerCase();
        const cleanSearchText = searchInputText.replace(/\./g, ''); // Xóa dấu chấm chuỗi nhập vào

        const rows = document.querySelectorAll('#data-rows tr');
        rows.forEach(row => {
            const rowCode = row.getAttribute('data-code').toLowerCase().replace(/\./g, ''); // Xóa dấu chấm mã lớp hệ thống
            const rowName = row.getAttribute('data-name').toLowerCase();

            if (rowName.includes(searchInputText) || rowCode.includes(cleanSearchText)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

   
    function notifyUpdating() {
        alert("error");
    }
</script>

